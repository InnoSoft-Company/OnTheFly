<?xml version="1.0"?>
<ruleset name="OnTheFly Coding Standards">
    <description>PSR-12 Coding Standards for OnTheFly</description>
    
    <file>./src/</file>
    <file>./onthefly.php</file>
    
    <arg value="sp"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>

    <rule ref="PSR12">
        <exclude name="PSR1.Files.SideEffects"/>
        <exclude name="PSR12.Files.FileHeader"/>
    </rule>
</ruleset>
